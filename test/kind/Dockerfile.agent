# Image used for the HTTPS-capture-via-eBPF kind cluster e2e.
#
# Builds inside a Linux Go container (multi-stage so the macOS host build
# environment isn't required), produces a small runtime image with libpcap,
# the bpf2go-generated .o file, and the agent binary.
#
# This is intentionally simpler than build-scripts/Dockerfile — we want
# something that boots quickly inside kind for the e2e demo, not the
# production release image.

FROM golang:1.24-bookworm AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
        clang llvm bpftool libbpf-dev libpcap-dev make git ca-certificates \
    && rm -rf /var/lib/apt/lists/*

RUN go install github.com/cilium/ebpf/cmd/bpf2go@v0.18.0
ENV PATH="/root/go/bin:${PATH}"

WORKDIR /src

# Download modules in a separate layer so Docker caches them and a flaky
# proxy.golang.org fetch can be retried without redoing apt/bpf2go setup.
COPY go.mod go.sum ./
RUN go mod download

COPY . .

# vmlinux.h must come from the *runtime* kernel's BTF, not the build host's.
# When kind nodes use the LinuxKit VM kernel (same as the dev container) this
# works; for non-kind production targets, vmlinux.h is generated at deploy
# time. The build-time vmlinux.h is committed to .gitignore.
RUN bpftool btf dump file /sys/kernel/btf/vmlinux format c > ebpf/programs/vmlinux.h && \
    cd ebpf/loader && go generate -tags insights_bpf ./... && cd /src && \
    go build -tags insights_bpf -o /out/postman-insights-agent .

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends \
        libpcap0.8 ca-certificates \
    && rm -rf /var/lib/apt/lists/*
COPY --from=builder /out/postman-insights-agent /usr/local/bin/postman-insights-agent
# Java agent JAR — used by the kube-webhook init container to seed the
# shared volume for instrumented pods. Built on the host via
# `cd java-agent && gradle shadowJar`; if missing the docker build fails fast.
COPY java-agent/build/libs/postman-java-agent.jar /opt/postman-java-agent.jar
# gRPC + combined REST/gRPC test workload (build:
#   cd java-agent/testdata/grpc-java && gradle shadowJar)
COPY java-agent/testdata/grpc-java/build/libs/grpc-java.jar /opt/grpc-java.jar
ENTRYPOINT ["/usr/local/bin/postman-insights-agent"]
