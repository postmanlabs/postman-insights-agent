# Dev container for HTTPS-capture-via-eBPF work.
# Provides the toolchain Phase 1 / Phase 2 need on a Linux kernel.
# Used from macOS + Docker Desktop; runs against the host kernel's BTF.
FROM golang:1.24-bookworm

RUN apt-get update && apt-get install -y --no-install-recommends \
        clang \
        llvm \
        bpftool \
        libbpf-dev \
        libpcap-dev \
        linux-headers-generic \
        make \
        git \
        curl \
        ca-certificates \
        pkg-config \
        sudo \
        procps \
        sysstat \
        iproute2 \
        net-tools \
        python3 \
        python3-requests \
        nodejs \
    && rm -rf /var/lib/apt/lists/*

# bpf2go used to materialize Go bindings from BPF C sources.
RUN go install github.com/cilium/ebpf/cmd/bpf2go@v0.18.0

# mockgen for `make mock`.
RUN go install github.com/golang/mock/mockgen@v1.5.0

ENV PATH="/root/go/bin:${PATH}"
WORKDIR /workspace
