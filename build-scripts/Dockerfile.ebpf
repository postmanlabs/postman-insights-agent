# eBPF-enabled build of postman-insights-agent.
#
# Produces a binary compiled with -tags insights_bpf so all eBPF paths
# (HTTPS capture via SSL uprobes) are included.
# Use this image for DaemonSet deployments that need --enable-https-capture.
#
# The standard build-scripts/Dockerfile builds WITHOUT eBPF (tags osusergo,netgo
# only) and is used for the non-eBPF release binary.

FROM golang:1.25-bookworm AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
        clang llvm bpftool libbpf-dev libpcap-dev make git ca-certificates \
    && rm -rf /var/lib/apt/lists/*

RUN go install github.com/cilium/ebpf/cmd/bpf2go@v0.18.0
ENV PATH="/root/go/bin:${PATH}"

WORKDIR /src

# Download modules in a separate layer so Docker caches them and a flaky
# proxy.golang.org fetch can be retried without redoing apt/bpf2go setup.
COPY go.mod go.sum ./
RUN go mod download

COPY . .

# Provide vmlinux.h for eBPF CO-RE. Prefer a header dropped into the build
# context; otherwise generate it from the build host's kernel BTF at build time.
# Must run on a Linux host whose kernel exposes /sys/kernel/btf/vmlinux, built
# NATIVELY for the target arch (CI and EC2 satisfy this; Apple Silicon cross-
# compiling does not — it would bake the wrong pt_regs layout). CO-RE relocations
# handle kernel-version differences at load time, so the builder kernel need not
# match the deployment kernel.
RUN set -eu; \
    if [ -f ebpf/programs/vmlinux.h ]; then \
        echo "==> using provided ebpf/programs/vmlinux.h"; \
    elif [ -r /sys/kernel/btf/vmlinux ]; then \
        echo "==> generating ebpf/programs/vmlinux.h from build host BTF"; \
        bpftool btf dump file /sys/kernel/btf/vmlinux format c > ebpf/programs/vmlinux.h.tmp \
            && mv ebpf/programs/vmlinux.h.tmp ebpf/programs/vmlinux.h \
            || { rm -f ebpf/programs/vmlinux.h.tmp; echo "ERROR: failed to generate vmlinux.h from build host BTF" >&2; exit 1; }; \
    else \
        echo "ERROR: ebpf/programs/vmlinux.h not provided and /sys/kernel/btf/vmlinux is unavailable in the build sandbox." >&2; \
        echo "Build on a Linux host with kernel BTF, or drop a pre-generated vmlinux.h into ebpf/programs/." >&2; \
        exit 1; \
    fi
RUN cd ebpf/loader && go generate -tags insights_bpf ./... && cd /src && \
    go build -tags insights_bpf -o /out/postman-insights-agent .

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends \
        libpcap0.8 ca-certificates \
    && rm -rf /var/lib/apt/lists/*
COPY --from=builder /out/postman-insights-agent /usr/local/bin/postman-insights-agent
# Requires privileged + CAP_BPF at runtime.
# See modules/insights_agent_mns/main.tf for the full capability set.
USER root

ENTRYPOINT ["/usr/local/bin/postman-insights-agent"]
